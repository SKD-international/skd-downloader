{
  "name": "skd-downloader",
  "version": "0.9.0-beta.6",
  "description": "A premium yt-dlp GUI for Mac and Windows — free Media Human alternative",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "native:build": "./script/build_and_run.sh --build",
    "native:package": "./script/build_and_run.sh --package",
    "native:notary:preflight": "./script/release_native.sh --preflight",
    "native:notary:setup": "./script/release_native.sh --setup-profile",
    "native:release": "./script/release_native.sh",
    "native:release:upload": "./script/release_native.sh --notarize --upload",
    "native:test": "swift test",
    "native:verify": "./script/build_and_run.sh --verify"
  },
  "build": {
    "appId": "com.skd.downloader",
    "productName": "SKD Downloader",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "lib/**/*",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ]
  },
  "keywords": [
    "yt-dlp",
    "youtube",
    "downloader",
    "video",
    "audio"
  ],
  "author": "SKD International",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
